# Mantle Sepolia deploy config for @afr/contracts.
# Copy to contracts/.env and fill locally. .env is gitignored — never commit real values.

# RPC endpoint for Mantle Sepolia (defaults to the public RPC if unset).
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz

# Deployer test wallet private key. Use a throwaway test account, never a main wallet.
# Required only for real deployment (005B). Leave empty for local dry-run.
MANTLE_SEPOLIA_PRIVATE_KEY=

# Source verification key (optional, 005B). Provide either one:
#   MANTLESCAN_API_KEY  — Mantlescan key
#   ETHERSCAN_API_KEY   — Etherscan V2 unified key (also covers Mantle Sepolia 5003)
MANTLESCAN_API_KEY=
ETHERSCAN_API_KEY=
